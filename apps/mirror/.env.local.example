# Convex Configuration
# Get these from your Convex dashboard after running `npx convex dev`
CONVEX_DEPLOYMENT=dev:your-deployment-name
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
NEXT_PUBLIC_CONVEX_SITE_URL=https://your-deployment.convex.site

# Site URL (your app's public URL)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Note: The following environment variables should be set in Convex dashboard,
# not in this file. Run these commands after setting up Convex:
#
# npx convex env set BETTER_AUTH_SECRET $(openssl rand -base64 32)
# npx convex env set SITE_URL http://localhost:3000
# npx convex env set GOOGLE_CLIENT_ID your-google-client-id
# npx convex env set GOOGLE_CLIENT_SECRET your-google-client-secret
# npx convex env set RESEND_API_KEY your-resend-api-key

# Tavus CVI (Video Conversations)
TAVUS_API_KEY=your-tavus-api-key
TAVUS_PERSONA_ID=pdced222244b
