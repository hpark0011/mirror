{
  "name": "@feel-good/convex",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./convex/_generated/api": "./convex/_generated/api.js",
    "./convex/_generated/dataModel": "./convex/_generated/dataModel.js",
    "./convex/_generated/server": "./convex/_generated/server.js",
    "./convex/*": "./convex/*"
  },
  "typesVersions": {
    "*": {
      "convex/_generated/api": [
        "./convex/_generated/api.d.ts"
      ],
      "convex/_generated/dataModel": [
        "./convex/_generated/dataModel.d.ts"
      ],
      "convex/_generated/server": [
        "./convex/_generated/server.d.ts"
      ]
    }
  },
  "scripts": {
    "dev": "convex dev",
    "deploy": "convex deploy",
    "generate": "convex codegen",
    "check-types": "tsc --noEmit -p convex/tsconfig.json",
    "seed:rick-rubin": "convex run seed:seedRickRubinDemo"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^2",
    "@ai-sdk/google": "^2",
    "@ai-sdk/openai": "^2",
    "@ai-sdk/provider-utils": "^3.0.7",
    "@convex-dev/agent": "^0.3.2",
    "@convex-dev/better-auth": "catalog:",
    "@convex-dev/rate-limiter": "^0.3.2",
    "@convex-dev/resend": "catalog:",
    "ai": "^5.0.29",
    "better-auth": "catalog:",
    "convex": "^1.32.0",
    "convex-helpers": "^0.1.113",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@feel-good/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "typescript": "catalog:"
  }
}
