        "./convex/_generated/dataModel.d.ts"
      ],
      "convex/_generated/server": [
        "./convex/_generated/server.d.ts"
      ],
      "convex/content/schema": [
        "./convex/content/schema.ts"
      ],
      "convex/content/slug": [
        "./convex/content/slug.ts"
      ],
      "convex/content/storagePolicy": [
        "./convex/content/storagePolicy.ts"
      ],
      "convex/content/bodyWalk": [
        "./convex/content/bodyWalk.ts"
      ],
      "convex/content/safeFetch": [
        "./convex/content/safeFetch.ts"
      ],
      "convex/content/markdownImport": [
        "./convex/content/markdownImport.ts"
      ],
      "convex/posts/categories": [
        "./convex/posts/categories.ts"
      ],
      "chat/tonePresets": [
        "./convex/chat/tonePresets.ts"
      ]
    }
  },
  "scripts": {
    "dev": "convex dev",
    "deploy": "convex deploy",
    "generate": "convex codegen",
    "check-types": "tsc --noEmit -p convex/tsconfig.json",
    "seed:rick-rubin": "convex run seed:seedRickRubinDemo",
    "test": "vitest run"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.74",
