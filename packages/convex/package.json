{
  "name": "@feel-good/convex",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./convex/_generated/api": "./convex/_generated/api.js",
    "./convex/_generated/dataModel": "./convex/_generated/dataModel.js",
    "./convex/_generated/server": "./convex/_generated/server.js",
    "./convex/content/schema": "./convex/content/schema.ts",
    "./convex/content/slug": "./convex/content/slug.ts",
    "./convex/content/storagePolicy": "./convex/content/storagePolicy.ts",
    "./convex/content/bodyWalk": "./convex/content/bodyWalk.ts",
    "./convex/content/safeFetch": "./convex/content/safeFetch.ts",
    "./convex/content/markdownImport": "./convex/content/markdownImport.ts",
    "./convex/posts/categories": "./convex/posts/categories.ts",
    "./convex/*": "./convex/*",
    "./chat/tonePresets": {
      "types": "./convex/chat/tonePresets.ts",
      "default": "./convex/chat/tonePresets.ts"
    }
  },
  "typesVersions": {
    "*": {
      "convex/_generated/api": [
