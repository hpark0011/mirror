    "@convex-dev/agent": "^0.6.1",
    "@convex-dev/better-auth": "catalog:",
    "@convex-dev/rate-limiter": "^0.3.2",
    "@convex-dev/resend": "catalog:",
    "ai": "^6.0.174",
    "better-auth": "catalog:",
    "convex": "^1.37.0",
    "convex-helpers": "^0.1.115",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@feel-good/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "convex-test": "^0.0.51",
    "typescript": "catalog:",
    "vitest": "^2.1.9"
